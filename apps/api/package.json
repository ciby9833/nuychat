{
  "name": "@nuychat/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "test": "vitest run",
    "db:migrate": "tsx --env-file=.env ./node_modules/knex/bin/cli.js migrate:latest --knexfile src/infra/db/knexfile.ts",
    "db:rollback": "tsx --env-file=.env ./node_modules/knex/bin/cli.js migrate:rollback --knexfile src/infra/db/knexfile.ts"
  },
  "dependencies": {
    "@fastify/cors": "*",
    "@fastify/helmet": "*",
    "@fastify/jwt": "*",
    "@fastify/sensible": "*",
    "bullmq": "*",
    "fastify": "*",
    "fastify-raw-body": "*",
    "ioredis": "*",
    "knex": "*",
    "pg": "*",
    "pino-pretty": "*",
    "zod": "*"
  },
  "devDependencies": {
    "@types/node": "*",
    "tsup": "*",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  }
}

