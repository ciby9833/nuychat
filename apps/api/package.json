{
  "name": "@nuychat/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "test": "vitest run",
    "db:check": "tsx --env-file=.env src/scripts/db-check.ts",
    "db:backfill:conversation-segments": "tsx --env-file=.env src/scripts/backfill-conversation-segments.ts",
    "db:backfill:conversation-cases": "tsx --env-file=.env src/scripts/backfill-conversation-cases.ts",
    "db:migrate": "tsx --env-file=.env ./node_modules/knex/bin/cli.js migrate:latest --knexfile src/infra/db/knexfile.ts",
    "db:rollback": "tsx --env-file=.env ./node_modules/knex/bin/cli.js migrate:rollback --knexfile src/infra/db/knexfile.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/static": "^9.0.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "bullmq": "5.70.4",
    "fastify": "5.8.2",
    "fastify-plugin": "5.1.0",
    "fastify-raw-body": "5.0.0",
    "ioredis": "5.10.0",
    "knex": "3.1.0",
    "pg": "8.20.0",
    "pino-pretty": "13.1.3",
    "socket.io": "4.8.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "@types/pg": "8.15.5",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
